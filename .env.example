# ============================================================
# AgroVision Environment Configuration Template
# Copy to .env and fill in values before running locally.
# Never commit .env to version control.
# ============================================================

# --- PostgreSQL ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=agrovision
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=agrovision

# Per-service DB names (each service owns its own schema)
IDENTITY_DB=identity_db
FARM_DB=farm_db
LIVESTOCK_DB=livestock_db
INVENTORY_DB=inventory_db
FINANCE_DB=finance_db
NOTIFICATION_DB=notification_db
REPORTING_DB=reporting_db

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me_in_production

# --- RabbitMQ ---
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=agrovision
RABBITMQ_PASSWORD=change_me_in_production
RABBITMQ_VHOST=agrovision

# --- JWT ---
JWT_SECRET_KEY=change_me_to_a_long_random_secret_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Service Ports (internal) ---
API_GATEWAY_PORT=8000
IDENTITY_SERVICE_PORT=8001
FARM_SERVICE_PORT=8002
LIVESTOCK_SERVICE_PORT=8003
INVENTORY_SERVICE_PORT=8004
FINANCE_SERVICE_PORT=8005
NOTIFICATION_SERVICE_PORT=8006
REPORTING_SERVICE_PORT=8007

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:80

# --- Environment ---
ENVIRONMENT=development
LOG_LEVEL=INFO
DEBUG=true
