# ============================================================
# AgroVision Environment Configuration Template
# Copy to .env and fill in values before running locally.
# Never commit .env to version control.
#
# M7 (2026-06-18): migrated from 8 microservices + RabbitMQ to a single
# modular-monolith app (one process, one consolidated database). Per-service
# DB names, RabbitMQ, and per-service ports are no longer used — removed
# below. See .project-governance/monolith-migration/ for the full record.
# ============================================================

# --- PostgreSQL ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=agrovision
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=agrovision

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me_in_production

# --- JWT ---
JWT_SECRET_KEY=change_me_to_a_long_random_secret_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- App port (internal) ---
MONOLITH_PORT=8100

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:80

# --- Environment ---
ENVIRONMENT=development
LOG_LEVEL=INFO
DEBUG=true
